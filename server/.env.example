# HeWork Server Environment Configuration

# Firebase Admin SDK
FIREBASE_PROJECT_ID=hework-messenger
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@hework-messenger.iam.gserviceaccount.com

# Email Configuration (verification@hework.io)
SMTP_HOST=smtp.hework.io
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=verification@hework.io
SMTP_PASS=your_email_password

# Server
PORT=3000
NODE_ENV=production

# App
APP_NAME=HeWork
APP_URL=https://hework.io
FRONTEND_URL=https://hework.io
